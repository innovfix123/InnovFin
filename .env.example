# InnovFin — environment template. Copy to .env (which is gitignored) and fill in.

# AI (OpenRouter) — used for upcoming RCM auto-classification etc.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Local database (persistence/history — reserved; not wired yet. NOTE: Prisma 7 needs a
# driver adapter + prisma.config.ts — to be set up when we commit persistence tech.)
DATABASE_URL="file:./dev.db"

# ---- Zoho Books (accounting automation) ----
# India data centre (.in). Create a Self Client / Server-based app at https://api-console.zoho.in
# Grant Books scopes (start read: ZohoBooks.settings.READ, ZohoBooks.banking.READ, etc.),
# then generate a refresh token. NEVER paste these into chat — put them here (.env is gitignored).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
# ZOHO_DC=in                 # override only if the org is on another data centre
# ZOHO_SYNC_LEDGER_PATH=     # override the default .data/zoho-sync-ledger.json

# ---- Gateway auto-fetch credentials (fill in to enable auto-fetch) ----
# Used by BOTH the sales/GST pipeline and the Gateway Settlements MCP (194H commission). Use each
# app's PAYIN / Payment-Gateway keys (NOT payout/money-moving keys). Naming: RAZORPAY_<APP>_KEY_ID/
# SECRET and CASHFREE_<APP>_APP_ID/SECRET_KEY, where <APP> is the app name upper-cased ("Only Care" →
# ONLY_CARE, "Bangalore Connect" → BANGALORE_CONNECT).
# Razorpay: Thedal, Sudar, Unman
RAZORPAY_THEDAL_KEY_ID=
RAZORPAY_THEDAL_KEY_SECRET=
RAZORPAY_THEDAL_WEBHOOK_SECRET=
RAZORPAY_SUDAR_KEY_ID=
RAZORPAY_SUDAR_KEY_SECRET=
RAZORPAY_UNMAN_KEY_ID=
RAZORPAY_UNMAN_KEY_SECRET=

# Cashfree: Hima, Only Care
CASHFREE_HIMA_APP_ID=
CASHFREE_HIMA_SECRET_KEY=
CASHFREE_ONLY_CARE_APP_ID=
CASHFREE_ONLY_CARE_SECRET_KEY=
# PhonePe (Hima's 2nd gateway + Bangalore Connect) — keys pending; the Gateway Settlements MCP skips
# and flags any gateway whose keys aren't present, so these slot in later without code changes.
# PHONEPE_HIMA_...=
# PHONEPE_BANGALORE_CONNECT_...=

# App dashboard DBs (read-only connection URL + a SELECT returning invoice-wise sales)
APPDB_HIMA_URL=
APPDB_HIMA_QUERY=
# Hima TDS creator payouts (read-only, PAN-scoped views tds_creator_payouts_v / payout_charges_v)
APPDB_HIMA_TDS_URL=
APPDB_HIMA_TDS_QUERY=
APPDB_ONLY_CARE_URL=
APPDB_ONLY_CARE_QUERY=
APPDB_UNMAN_URL=
APPDB_UNMAN_QUERY=

# Bank statements + GSTR-2B = manual (downloaded from the GST portal).

# --- Login gate: shared password for allow-listed team emails + session-signing secret ---
AUTH_PASSWORD=change-me-to-a-strong-password
AUTH_SECRET=generate-with: openssl rand -base64 32

# --- Only Care TDS MCP: per-user bearer tokens for the networked endpoint ---
# One secret per user, keyed by name: ONLYCARE_MCP_TOKEN_<USER>. The <USER> suffix is the
# identity written to the access log. Add a user = add a line + `pm2 restart innovfin`.
# Revoke a user = delete their line + `pm2 restart innovfin`. Never share one token between users.
# Generate: node -e 'console.log("oct_"+require("crypto").randomBytes(24).toString("base64url"))'
ONLYCARE_MCP_TOKEN_JP=oct_generate-a-unique-token
ONLYCARE_MCP_TOKEN_SHOYAB=oct_generate-a-unique-token

# Native Claude connector (OAuth): identity reuses the portal login (AUTH_PASSWORD/AUTH_SECRET);
# this allowlist decides who may actually use the Only Care TDS MCP. Comma-separated emails.
# Revoke a user = remove their email + `pm2 restart innovfin`. Defaults to JP/Shoyab/Fida if unset.
ONLYCARE_MCP_ALLOWED_EMAILS=jp@innovfix.in,shoyab@innovfix.in,fida@innovfix.in

# --- Hima TDS MCP: same shape as Only Care (per-user bearer tokens + OAuth allowlist) ---
HIMA_MCP_TOKEN_JP=
HIMA_MCP_TOKEN_SHOYAB=
HIMA_MCP_TOKEN_FIDA=
HIMA_MCP_ALLOWED_EMAILS=jp@innovfix.in,shoyab@innovfix.in,fida@innovfix.in

# --- Gateway Settlements MCP (194H commission): per-user bearer tokens + OAuth allowlist ---
# Generate a token: node -e 'console.log("gws_"+require("crypto").randomBytes(24).toString("base64url"))'
GATEWAY_MCP_TOKEN_JP=
GATEWAY_MCP_TOKEN_SHOYAB=
GATEWAY_MCP_TOKEN_FIDA=
GATEWAY_MCP_ALLOWED_EMAILS=jp@innovfix.in,shoyab@innovfix.in,fida@innovfix.in
# Optional overrides for the Gateway Settlements MCP:
#   GATEWAY_MCP_ORIGIN=https://gst.innovfix.ai          # public origin (issuer/resource base)
#   GATEWAY_DEMINIMIS_INR=1.00                           # de-minimis flag cutoff (UNCONFIRMED w/ Shoyab)
#   GATEWAY_PAN_CASHFREE=AAICP2912R                      # deductee PAN per gateway (Cashfree known; set
#   GATEWAY_PAN_RAZORPAY=                                #   Razorpay/PhonePe once confirmed with Shoyab —
#   GATEWAY_PAN_PHONEPE=                                 #   NEVER Innovfix's own PAN (the filed autofill bug)

# --- Google Drive tools: live bridge to ONE shared Drive folder (Single Source of Truth) ---
# These tools are MOUNTED INTO the gstr2b-estimate MCP as drive_* — there is no separate /mcp/drive
# endpoint, so INBOUND auth (bearer tokens, OAuth allowlist) is whatever gstr2b-estimate already uses.
#
# OUTBOUND auth (server → Google). Preferred: USER OAUTH as the account that OWNS the folder. Required
# here because the Cloud org enforces iam.disableServiceAccountKeyCreation (SA JSON keys can't be
# downloaded); it also avoids the SA storage-quota limit on writes.
#   1) Google Cloud Console → project → enable "Google Drive API".
#   2) APIs & Services → Credentials → Create credentials → OAuth client ID → Desktop app.
#   3) Put the client id/secret below, then run:  npm run drive:auth  → paste the printed refresh token.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
#
# Fallback (only where SA keys ARE allowed): a service account shared into the folder. Provide the key
# EITHER inline as one line (escape newlines as \n) OR as a file path — not both:
#   GOOGLE_SA_KEY_JSON=
#   GOOGLE_SA_KEY_FILE=/var/www/innovfin/secrets/drive-sa.json
#
# The folder ID is the last path segment of https://drive.google.com/drive/folders/<THIS_IS_THE_ID>
DRIVE_FOLDER_ID=
#
# WRITE tools (drive_create_folder, drive_upload_text_file, drive_update_file_content, drive_rename_file,
# drive_move_file, drive_trash_file). OFF by default (read-only). To enable: consent with write scope
# (set this flag BEFORE running drive:auth) and set the flag below. Removal is Trash-only (recoverable)
# — there is no permanent-delete tool.
#   DRIVE_MCP_WRITE=1
