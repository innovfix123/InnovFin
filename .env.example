# InnovFin — environment template. Copy to .env (which is gitignored) and fill in.

# AI (OpenRouter) — used for upcoming RCM auto-classification etc.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Local database (persistence/history — reserved; not wired yet. NOTE: Prisma 7 needs a
# driver adapter + prisma.config.ts — to be set up when we commit persistence tech.)
DATABASE_URL="file:./dev.db"

# ---- Zoho Books (accounting automation) ----
# India data centre (.in). Create a Self Client / Server-based app at https://api-console.zoho.in
# Grant Books scopes (start read: ZohoBooks.settings.READ, ZohoBooks.banking.READ, etc.),
# then generate a refresh token. NEVER paste these into chat — put them here (.env is gitignored).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
# ZOHO_DC=in                 # override only if the org is on another data centre
# ZOHO_SYNC_LEDGER_PATH=     # override the default .data/zoho-sync-ledger.json

# ---- Gateway auto-fetch credentials (fill in to enable auto-fetch) ----
# Razorpay: Sudar, Unman
RAZORPAY_SUDAR_KEY_ID=
RAZORPAY_SUDAR_KEY_SECRET=
RAZORPAY_UNMAN_KEY_ID=
RAZORPAY_UNMAN_KEY_SECRET=

# Cashfree: Only Care
CASHFREE_ONLY_CARE_APP_ID=
CASHFREE_ONLY_CARE_SECRET_KEY=

# App dashboard DBs (read-only connection URL + a SELECT returning invoice-wise sales)
APPDB_HIMA_URL=
APPDB_HIMA_QUERY=
# Hima TDS creator payouts (read-only, PAN-scoped views tds_creator_payouts_v / payout_charges_v)
APPDB_HIMA_TDS_URL=
APPDB_HIMA_TDS_QUERY=
APPDB_ONLY_CARE_URL=
APPDB_ONLY_CARE_QUERY=
APPDB_UNMAN_URL=
APPDB_UNMAN_QUERY=

# Bank statements + GSTR-2B = manual (downloaded from the GST portal).

# --- Login gate: shared password for allow-listed team emails + session-signing secret ---
AUTH_PASSWORD=change-me-to-a-strong-password
AUTH_SECRET=generate-with: openssl rand -base64 32

# --- Only Care TDS MCP: per-user bearer tokens for the networked endpoint ---
# One secret per user, keyed by name: ONLYCARE_MCP_TOKEN_<USER>. The <USER> suffix is the
# identity written to the access log. Add a user = add a line + `pm2 restart innovfin`.
# Revoke a user = delete their line + `pm2 restart innovfin`. Never share one token between users.
# Generate: node -e 'console.log("oct_"+require("crypto").randomBytes(24).toString("base64url"))'
ONLYCARE_MCP_TOKEN_JP=oct_generate-a-unique-token
ONLYCARE_MCP_TOKEN_SHOYAB=oct_generate-a-unique-token

# Native Claude connector (OAuth): identity reuses the portal login (AUTH_PASSWORD/AUTH_SECRET);
# this allowlist decides who may actually use the Only Care TDS MCP. Comma-separated emails.
# Revoke a user = remove their email + `pm2 restart innovfin`. Defaults to JP/Shoyab/Fida if unset.
ONLYCARE_MCP_ALLOWED_EMAILS=jp@innovfix.in,shoyab@innovfix.in,fida@innovfix.in
