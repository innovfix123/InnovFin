{
  "name": "innovfin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp:onlycare": "tsx src/mcp/onlycare-tds/server.ts",
    "mcp:onlycare:check": "tsx src/mcp/onlycare-tds/check-anchor.ts",
    "mcp:onlycare:kyc": "tsx src/mcp/onlycare-tds/check-kyc.ts",
    "mcp:hima": "tsx src/mcp/hima-tds/server.ts",
    "mcp:hima:check": "tsx src/mcp/hima-tds/check-anchor.ts",
    "mcp:hima:smoke": "tsx src/mcp/hima-tds/smoke.ts",
    "mcp:hima:kyc": "tsx src/mcp/hima-tds/check-kyc.ts",
    "mcp:gateway": "tsx src/mcp/gateway-settlements/server.ts",
    "mcp:gateway:check": "tsx src/mcp/gateway-settlements/check-anchor.ts",
    "mcp:gateway:smoke": "tsx src/mcp/gateway-settlements/smoke.ts",
    "mcp:tds-working": "tsx src/mcp/tds-working/server.ts",
    "mcp:gstr2b": "tsx src/mcp/gstr2b-estimate/server.ts",
    "mcp:gstr2b:smoke": "tsx src/mcp/gstr2b-estimate/smoke.ts",
    "recon:check": "tsx --env-file=.env --max-old-space-size=8192 src/lib/recon/check-june.ts",
    "mcp:invoice": "cd invoice-intelligence && .venv/bin/python -m mcp_server.server",
    "mcp:invoice:http": "invoice-intelligence/scripts/run_mcp_innovfin.sh",
    "mcp:invoice:test": "cd invoice-intelligence && .venv/bin/python -m pytest -q",
    "mcp:invoice:pipeline": "cd invoice-intelligence && .venv/bin/python cli.py collect && .venv/bin/python cli.py pipeline",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^7.8.0",
    "mysql2": "^3.22.5",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
